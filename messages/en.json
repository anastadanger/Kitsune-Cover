  "customStudio": {
    "metaTitle": "Custom Studio — Kitsune Cover",
    "metaDescription": "How phone case customization works: prints, clear styles, camera accents, grips, and MagSafe-ready builds — with visual references.",
    "eyebrow": "Design lab",
    "titleFill": "Custom",
    "titleOutline": "studio",
    "lead": "Not every case is a plain shell. Between official collab graphics and personal artwork, customization turns a phone into a wearable poster.",
    "intro": "Brands like CASETiFY made modular flows mainstream: upload art, pick a case line, then layer camera rings, straps, or MagSafe add-ons. The best results read intentional — editorial layout, not random stickers.",
    "typesTitle": "What you can customize",
    "types": [
      {
        "title": "Print & finish",
        "body": "Edge-to-edge UV-style prints with glossy or matte top coats — graphics that survive corner impacts without flaking."
      },
      {
        "title": "Clear & tinted bases",
        "body": "Crystal clears to show the device finish, or smoke and frost tints that soften glare and fingerprints."
      },
      {
        "title": "Camera island graphics",
        "body": "Rings, stripes, and type around the lens stack so the camera module reads as a designed frame."
      },
      {
        "title": "Grip & stand add-ons",
        "body": "Finger loops, fold stands, and card pockets that attach to compatible shells for one-handed use and travel."
      },
      {
        "title": "MagSafe alignment",
        "body": "Magnet layouts matched to chargers and wallets — confirm compatibility before locking your artwork so accessories snap cleanly."
      }
    ],
    "galleryTitle": "Reference mood",
    "galleryLead": "Three directions teams use when a case should feel editorial: loud print, disciplined clear, accessory-forward.",
